test metrics() {
    using unpack();

    assert(y_min == -2);
    assert(y_max == 10);
    assert(x_min == 0);
    assert(x_max == 6);
    assert(ascender == 7);
    assert(cap_height == 7);
    assert(x_height == 5);
    assert(descender == -2);
}
