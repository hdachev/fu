
type Codepoint = u32;


// Bytes for unicode point.

fn utf8(codepoint: Codepoint)
{
    if (codepoint <= 0x7f)
        return [
            byte(codepoint),
        ];

    if (codepoint <= 0x07ff)
        return [
            byte(((codepoint >> 6) & 0x1f) | 0xc0),
            byte(((codepoint >> 0) & 0x3f) | 0x80),
        ];

    if (codepoint <= 0xffff)
        return [
            byte(((codepoint >> 12) & 0x0f) | 0xe0),
            byte(((codepoint >>  6) & 0x3f) | 0x80),
            byte(((codepoint >>  0) & 0x3f) | 0x80),
        ];

    if (codepoint <= 0x10ffff)
        return [
            byte(((codepoint >> 18) & 0x07) | 0xf0),
            byte(((codepoint >> 12) & 0x3f) | 0x80),
            byte(((codepoint >>  6) & 0x3f) | 0x80),
            byte(((codepoint >>  0) & 0x3f) | 0x80),
        ];

    return [];
}

fn codepoints(utf8: byte[..], each, error?)
{
    for (mut i = 0; i < utf8.len; i++)
    {
        let lax i0 = i;

        :BREAK_ON_ERROR
        {
            mut c = utf8[i].u32;
            if (c >= 0x80)
            {
                mut extra = 0;
                if      (c & 0xe0 == 0xc0) // Starts with 0b110.
                    extra = 1;
                else if (c & 0xf0 == 0xe0) // Starts with 0b1110.
                    extra = 2;
                else if (c & 0xf8 == 0xf0) // Starts with 0b11110.
                    extra = 3;
                else
                    break :BREAK_ON_ERROR;

                c &= 0x3f >> extra.u32;

                //
                let i1 = i + extra;
                if (utf8.len < i1) {
                    break :BREAK_ON_ERROR;
                }

                do {
                    i++;
                    mut b = utf8[i].u32;
                    if (b & 0xc0 != 0x80) // Must start with 0b10.
                        break :BREAK_ON_ERROR;

                    b &= ~0xc0;
                    c <<= 6;
                    c |= b;
                }
                while (i < i1);
            }

            // Only called once,
            //  so the each-codepoint block can inline uniquely.
            //
            each(c.Codepoint, i?: i);
            continue;
        }

        // BREAK_ON_ERROR:
        //
        // Again, only called once,
        //  so the each-error block can inline uniquely.
        //
        error(i?: i0);
    }
}

test utf8_roundtrip() {
    fn ok(TEST: string) {
        mut roundtrip = "";

        TEST.codepoints(
            each: |codepoint| roundtrip ~= utf8(:codepoint),
            error: || assert(false));

        return TEST == roundtrip;
    }

    assert(ok("H"));
    assert(ok("Â"));
    assert(ok("中"));
    assert(ok("🏀"));

