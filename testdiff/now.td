    fu::vec<int> items;
    explicit operator bool() const noexcept
    {
        return false
            || items
        ;
    }
};
                                #endif

#ifndef fu_NO_fdefs

static X_9ItJ popfirst_MbR9(/*1:1*/ fu::view<X_9ItJ> arr)
{
    return X_9ItJ(arr[0]);
}

int fu_MAIN()
{
