        fn Find !<T>(ref arr: T[], needle: T, visit) {
            for (mut i = 0; i < arr.len; i++) {
                ref item = arr[i];
                if (item == needle) {
                    visit(i?: i, remove?: |ret = true| {
                        arr.splice(i, 1);
                        return ret;
                    });
                    return true;
                }
            }
            return [];
        }

        fn main() {
            mut arr = [1, 2, 3, 4];
            let x = arr.Find(2, |i, remove!| remove(i));
            return x - 1;
        }

