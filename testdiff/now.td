#ifndef fu_NO_fdefs

static int pretend_pure_MbR9(int res)
{
    static int counter = 100;
    res += counter++;

    return res;
}

static int licm_loop_preheader_MbR9(const int n)
{
    int res = 0;
    int must_hoist;

    {
        int i = 0;
        if (i < n)
        {
